DATABASE_URL=sqlite://data/intelliread.db?mode=rwc
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRATION_SECONDS=86400
SERVER_HOST=127.0.0.1
SERVER_PORT=3000
RUST_LOG=intelliread_backend=info,tower_http=info
MAX_DOCUMENT_BYTES=2097152
CORS_ALLOWED_ORIGINS=http://localhost:5173
AI_PROVIDER=local-deterministic
# To use DeepSeek V4 Pro locally, set:
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=replace-me
AI_API_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-pro
AI_TIMEOUT_SECONDS=30
AI_MAX_OUTPUT_TOKENS=1200
AI_THINKING=disabled
